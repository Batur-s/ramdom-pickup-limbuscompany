// This is your Prisma schema file.
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  provider   String
  providerId String
  email      String   @unique
  nickName   String
  isNewUser  Boolean  @default(true)
  password   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userIdentity UserIdentity[]
  games        Games[]

  @@unique([provider, providerId])
}

model UserIdentity {
  id         String @id @default(cuid())
  userId     String
  identityId String
  syncGrade  Int    @default(1)

  user     User     @relation(fields: [userId], references: [id])
  identity Identity @relation(fields: [identityId], references: [id])

  gameDecks GameDecks[]

  @@unique([userId, identityId])
}

model Identity {
  id       String  @id @default(cuid())
  name     String
  sinnerId String
  grade    Int
  tier     Tier
  imageUrl String?

  sinner            Sinners             @relation(fields: [sinnerId], references: [id])
  userIdentity      UserIdentity[]
  gameRerollResults GameRerollResults[]
}

model Sinners {
  id   String @id @default(cuid())
  name String @unique

  identity Identity[]
}

model Games {
  id           String     @id @default(cuid())
  status       GameStatus @default(PAUSE)
  currentFloor Int        @default(1)
  title        String
  userId       String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id])

  gameDecks GameDecks[]

  gameStages GameStages[]

  gameRerolls GameRerolls[]
}

// 덱(초기 버전): 기존을 유지. 리롤 교체가 중요해지면 GameDecks를 슬롯 모델로 교체 권장.
model GameDecks {
  id             String @id @default(cuid())
  gameId         String
  userIdentityId String
  sinnerId       String

  games        Games        @relation(fields: [gameId], references: [id])
  userIdentity UserIdentity @relation(fields: [userIdentityId], references: [id])

  @@unique([gameId, sinnerId])
  @@index([gameId])
}

model Stages {
  id           String @id @default(cuid())
  normalFloorA Int?
  normalFloorB Int?
  hardFloorA   Int?
  hardFloorB   Int?
  name         String

  gameStages GameStages[]
}

model GameStages {
  id      String @id @default(cuid())
  gameId  String
  stageId String
  floor   Int

  games  Games  @relation(fields: [gameId], references: [id])
  stages Stages @relation(fields: [stageId], references: [id])

  @@unique([gameId, stageId])
  @@index([gameId])
}

model GameRerolls {
  id          String   @id @default(cuid())
  gameId      String
  floor       Int?
  rerollIndex Int
  createdAt   DateTime @default(now())

  // 확률/가중치 모델 버전/재현을 위해(옵션)
  probabilityModelVersion Int?
  seed                    String?

  game    Games               @relation(fields: [gameId], references: [id])
  results GameRerollResults[]

  @@index([gameId, floor])
}

model GameRerollResults {
  id         String @id @default(cuid())
  rerollId   String
  identityId String

  rolledTier Tier
  rankInRoll Int?

  appliedToDeckSlotId String?

  reroll   GameRerolls @relation(fields: [rerollId], references: [id])
  identity Identity    @relation(fields: [identityId], references: [id])

  @@index([identityId])
}

//// --- Enums ---

enum GameStatus {
  CLEAR
  FAILURE
  PAUSE
}

enum Tier {
  S
  A
  B
  C
  D
  E
}
